{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/logo-patch.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "admin.softsyncsolutions.in"
        }
      ],
      "destination": "/admin-login.html",
      "permanent": false
    },
    {
      "source": "/admin-login.html",
      "has": [
        {
          "type": "host",
          "value": "softsyncsolutions.in"
        }
      ],
      "destination": "https://admin.softsyncsolutions.in/",
      "permanent": true
    },
    {
      "source": "/admin-dashboard.html",
      "has": [
        {
          "type": "host",
          "value": "softsyncsolutions.in"
        }
      ],
      "destination": "https://admin.softsyncsolutions.in/admin-dashboard.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon-48x48.png"
    },
    {
      "source": "/dashboard",
      "has": [
        {
          "type": "host",
          "value": "admin.softsyncsolutions.in"
        }
      ],
      "destination": "/admin-dashboard.html"
    }
  ]
}
